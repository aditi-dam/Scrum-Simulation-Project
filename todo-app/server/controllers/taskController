require("dotenv").config();
const { readStore, writeStore } = require("../services/dataStore");

function fallbackCategory(title) {
  const t = title.toLowerCase();

  if (
    t.includes("study") ||
    t.includes("hw") ||
    t.includes("homework") ||
    t.includes("exam") ||
    t.includes("class")
  ) return "school";

  if (
    t.includes("meeting") ||
    t.includes("work") ||
    t.includes("project") ||
    t.includes("job") ||
    t.includes("email")
  ) return "work";

  return "home";
}

exports.getTasks = async (req, res) => {
  if (!req.session.user) {
    return res.status(401).json({ error: "You must be logged in." });
  }

  const userId = req.session.user.id;
  const store = await readStore();
  const userTasks = store.tasks.filter((task) => task.userId === userId);

  res.json(userTasks);
};

exports.addTask = async (req, res) => {
  if (!req.session.user) {
    return res.status(401).json({ error: "You must be logged in." });
  }

  const { title, dueDate, category, color } = req.body;

  let finalCategory = category ? category.toLowerCase() : "auto";

  if (!finalCategory || finalCategory === "auto") {
    finalCategory = fallbackCategory(title);
  }

  const userId = req.session.user.id;
  const store = await readStore();

  const newTask = {
    id: Date.now().toString(),
    userId: userId,
    title,
    completed: false,
    category: finalCategory || "uncategorized",
    dueDate: dueDate || null,
    color: color || "#000000"
  };

  store.tasks.push(newTask);
  await writeStore(store);

  res.json(newTask);
};

exports.deleteTask = async (req, res) => {
  if (!req.session.user) {
    return res.status(401).json({ error: "You must be logged in." });
  }

  const userId = req.session.user.id;
  const id = req.params.id;
  const store = await readStore();

  store.tasks = store.tasks.filter(
    (task) => !(task.id === id && task.userId === userId)
  );

  await writeStore(store);
  res.json({ message: "Task deleted" });
};

exports.updateTask = async (req, res) => {
  if (!req.session.user) {
    return res.status(401).json({ error: "You must be logged in." });
  }

  const userId = req.session.user.id;
  const id = req.params.id;
  const { completed, category, dueDate, color } = req.body;
  const store = await readStore();

  store.tasks = store.tasks.map((task) => {
    if (task.id === id && task.userId === userId) {
      return {
        ...task,
        completed: completed !== undefined ? completed : task.completed,
        category: category !== undefined ? category.toLowerCase() : task.category,
        dueDate: dueDate !== undefined ? dueDate : task.dueDate,
        color: color !== undefined ? color : task.color
      };
    }
    return task;
  });

  await writeStore(store);
  res.json({ message: "Task updated" });
};