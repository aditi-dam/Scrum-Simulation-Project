require("dotenv").config();

let tasks = [];

function fallbackCategory(title) {
  const t = title.toLowerCase();

  if (
    t.includes("study") ||
    t.includes("hw") ||
    t.includes("homework") ||
    t.includes("exam") ||
    t.includes("class")
  ) return "school";

  if (
    t.includes("meeting") ||
    t.includes("work") ||
    t.includes("project") ||
    t.includes("job") ||
    t.includes("email")
  ) return "work";

  return "home";
}

exports.getTasks = (req, res) => {
  res.json(tasks);
};

exports.addTask = async (req, res) => {
  const { title, dueDate, category, color } = req.body;

  let finalCategory = category ? category.toLowerCase() : "auto";

  if (!finalCategory || finalCategory === "auto") {
    finalCategory = fallbackCategory(title);
  }

  const newTask = {
    id: Date.now(),
    title,
    completed: false,
    category: finalCategory || "uncategorized",
    dueDate: dueDate || null,
    color: color || "#000000",
  };

  tasks.push(newTask);
  res.json(newTask);
};

exports.deleteTask = (req, res) => {
  const id = Number(req.params.id);
  tasks = tasks.filter((task) => task.id !== id);
  res.json({ message: "Task deleted" });
};

exports.updateTask = (req, res) => {
  const id = Number(req.params.id);
  const { completed, category, dueDate, color } = req.body;

  tasks = tasks.map((task) => {
    if (task.id === id) {
      return {
        ...task,
        completed: completed !== undefined ? completed : task.completed,
        category: category !== undefined ? category.toLowerCase() : task.category,
        dueDate: dueDate !== undefined ? dueDate : task.dueDate,
        color: color !== undefined ? color : task.color,
      };
    }
    return task;
  });

  res.json({ message: "Task updated" });
};